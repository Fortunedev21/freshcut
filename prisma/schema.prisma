// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Authentication & Users
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN         // Coiffeur (gère ses RDV)
  SUPER_ADMIN   // Boss (gère tout)
}

// ============================================
// Haircut Styles (Coiffures/Lookbook) - Admin can add with photos
// ============================================

model Coupe {
  id                String   @id @default(cuid())
  nom               String   @unique
  description       String
  tempsEstimation   String   // "45 min", "60 min"
  difficulte        Int      // 1-5 difficulty level
  image             String   // URL or path to photo
  conseils          String[] // Array of care tips
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([difficulte])
}

// ============================================
// Products (Boutique)
// ============================================

model Product {
  id          String   @id @default(cuid())
  nom         String
  categorie   String   // BARBE, CHEVEUX, ACCESSOIRES, MERCHANDISING
  prix        Int      // in FCFA
  description String
  image       String?
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categorie])
}

// ============================================
// Services (Haircut & Beard Services)
// ============================================

model Service {
  id          String    @id @default(cuid())
  nom         String    @unique
  categorie   String    // Coupe, Barbe, Combos, Soins
  description String
  duree       Int       // minutes
  prix        Int       // in FCFA
  badge       String?   // "Populaire", "Meilleure valeur"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    Booking[]

  @@index([categorie])
}

// ============================================
// Bookings (Reservations)
// ============================================

model Booking {
  id            String         @id @default(cuid())
  phoneNumber   String
  firstName     String
  lastName      String
  email         String?
  serviceId     String
  service       Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  coupeId       String?        // Optional: Quelle coupe réservée?
  barberIdAssigned String?     // Quel coiffeur fait le RDV?
  date          DateTime
  time          String         // "09:00"
  status        BookingStatus  @default(PENDING)
  advanceAmount Int            // Advance payment in FCFA
  totalAmount   Int            // Total price in FCFA
  notes         String?
  validatedAt   DateTime?      // Quand confirmé par coiffeur
  completedAt   DateTime?      // Quand terminé
  cancelledAt   DateTime?      // Quand annulé
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([phoneNumber])
  @@index([date])
  @@index([status])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ============================================
// Clients (Loyalty Program)
// ============================================

model Client {
  id        String   @id @default(cuid())
  phone     String   @unique
  firstName String
  lastName  String
  points    Int      @default(0)   // 0-9, 10 = free service
  totalSpent Int     @default(0)   // Total money spent
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
}

// ============================================
// Inventory & Stock Tracking
// ============================================

model InventoryLog {
  id        String   @id @default(cuid())
  productId String
  oldStock  Int
  newStock  Int
  reason    String   // "SALE", "RESTOCK", "DAMAGE", "ADJUSTMENT"
  createdAt DateTime @default(now())

  @@index([productId])
}

// ============================================
// Financial Records
// ============================================

model Invoice {
  id            String   @id @default(cuid())
  bookingId     String   @unique
  amount        Int
  paymentMethod String   // "CASH", "MOBILE_MONEY", "CARD"
  status        String   // "PAID", "PENDING", "REFUNDED"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
}

// ============================================
// Barber Availability
// ============================================

model BarberAvailability {
  id          String   @id @default(cuid())
  barberId    String   // Email of the barber (admin user)
  dayOfWeek   Int      // 0 = Monday, 6 = Sunday
  startTime   String   // "09:00"
  endTime     String   // "18:00"
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([barberId, dayOfWeek])
}
