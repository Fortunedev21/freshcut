generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Authentication & Users
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  SUPER_ADMIN
}

model Coupe {
  id                String   @id @default(cuid())
  nom               String   @unique
  description       String
  tempsEstimation   String   // "45 min", "60 min"
  difficulte        Int      // 1-5 difficulty level
  image             String   // URL or path to photo
  conseils          String[] // Array of care tips
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([difficulte])
}

// ============================================
// Products (Boutique)
// ============================================

model Product {
  id          String   @id @default(cuid())
  nom         String
  categorie   String   
  prix        Int      
  description String
  image       String?
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categorie])
}

enum ClientType {
  ADULTE
  ETUDIANT
  ENFANT
}

// ============================================
// Services & Reservations
// ============================================

model Service {
  id          String         @id @default(cuid())
  nom         String         @unique
  categorie   String         
  description String
  duree       Int       
  badge       String?   
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  bookings    Booking[]
  prices      ServicePrice[]

  @@index([categorie])
}

model ServicePrice {
  id        String     @id @default(cuid())
  serviceId String
  service   Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  clientType ClientType
  prix      Int 
  instructions String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([serviceId, clientType]) 
  @@index([serviceId])
}

model Booking {
  id            String         @id @default(cuid())
  phoneNumber   String
  firstName     String
  lastName      String
  email         String?
  serviceId     String
  service       Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  coupeId       String?        
  barberIdAssigned String?     
  date          DateTime
  time          String         
  status        BookingStatus  @default(PENDING)
  advanceAmount Int
  totalAmount   Int
  notes         String?
  validatedAt   DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([phoneNumber])
  @@index([date])
  @@index([status])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Client {
  id        String   @id @default(cuid())
  phone     String   @unique
  firstName String
  lastName  String
  points    Int      @default(0) 
  totalSpent Int     @default(0) 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
}


model InventoryLog {
  id        String   @id @default(cuid())
  productId String
  oldStock  Int
  newStock  Int
  reason    String
  createdAt DateTime @default(now())

  @@index([productId])
}

model Invoice {
  id            String   @id @default(cuid())
  bookingId     String   @unique
  amount        Int
  paymentMethod String 
  status        String 
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
}



model BarberAvailability {
  id          String   @id @default(cuid())
  barberId    String   // Email of the barber (admin user)
  dayOfWeek   Int      // 0 = Monday, 6 = Sunday
  startTime   String   // "09:00"
  endTime     String   // "18:00"
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([barberId, dayOfWeek])
}
